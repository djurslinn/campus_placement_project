# Environment variables for sensitive data
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL Database Configuration
DB_PASSWORD=your_postgres_password

# Django Secret Key (generate a new one for production)
SECRET_KEY=your_secret_key_here

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated, e.g. .onrender.com,localhost)
ALLOWED_HOSTS=*

# Resume Settings
MAX_RESUME_SIZE_MB=5

# Email Configuration (Gmail SMTP)
# Step 1: Enable 2-Step Verification on your Google account
# Step 2: Go to https://myaccount.google.com/apppasswords
# Step 3: Create an App Password (select "Mail")
# Step 4: Paste the 16-character password below
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_16_char_app_password
DEFAULT_FROM_EMAIL=Campus Placement <your_email@gmail.com>

# ATS Microservice URL (only needed if running the ATS service separately)
ATS_SERVICE_URL=http://127.0.0.1:8001
